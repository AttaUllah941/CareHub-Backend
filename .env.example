# Server
NODE_ENV=development
PORT=5800
API_PREFIX=/api/v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/carehub
MONGODB_POOL_SIZE=50

# JWT (access token should be short-lived; refresh token longer)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# CORS (comma-separated; in development any localhost port is also allowed)
CORS_ORIGIN=http://localhost:4200
FRONTEND_URL=http://localhost:4200

# Password Reset (token expiry in milliseconds, default 1 hour)
PASSWORD_RESET_EXPIRES_MS=3600000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# File uploads (future modules)
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5

# Redis (Bull queues)
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLED=true

# SMTP (optional — emails are logged to console when not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CareHub <noreply@carehub.local>
