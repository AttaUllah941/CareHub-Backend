# Server
NODE_ENV=development
PORT=5800

# MongoDB
MONGODB_URI=mongodb://localhost:27017/carehub

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Password reset (milliseconds)
PASSWORD_RESET_EXPIRES_MS=3600000

# Frontend (used in password reset email stub)
FRONTEND_URL=http://localhost:4200

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:4200

# Redis (optional — for queues/caching later)
REDIS_URL=

# SMTP (optional — for email later)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# AWS (optional — for file storage later)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=
